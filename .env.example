# FIXED: exemplo consolidado de variáveis de ambiente usadas no projeto

########################################
# Banco principal da aplicação / Supabase
########################################

# URL completa de conexão (usada pelo backend/app/config.py)
# Exemplo Supabase:
# postgresql://postgres.<instance-id>:<password>@aws-0-us-west-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/steam_db

# Modo de SSL:
#   require  -> SSL com verificação (produção - default)
#   insecure -> SSL sem verificação (apenas debug local)
#   disable  -> sem SSL (Postgres local)
DB_SSL_MODE=require

########################################
# Supabase REST / Chaves (opcional)
########################################

SUPABASE_URL=
SUPABASE_KEY=

########################################
# Redis (cache analítico)
########################################

REDIS_URL=redis://localhost:6379/0

########################################
# Segurança
########################################

SECRET_KEY=troque-esta-chave-em-producao

# Ambiente de execução: development | production | test
ENVIRONMENT=development

# Origens permitidas pelo CORS (separadas por vírgula)
# Produção: use o domínio real, nunca '*'
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:8000

# Diretório raiz de artefatos ML treinados
MODELS_PATH=models/

# Diretório raiz de dados (raw + processed)
DATA_PATH=data/


########################################
# Scripts de população / extração
########################################

# Conexão direta usada em populate_supabase*.py
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=steam_db

########################################
# Caminhos de datasets locais (EDA / validação)
########################################

# Caminho absoluto ou relativo para o CSV bruto da Steam
# Exemplo Windows: D:\datasets\steam\games.csv
RAW_STEAM_DATA_PATH=data/raw/games.csv

# Caminho para o CSV imputado gerado pelo pipeline v2 (se diferente do default)
IMPUTED_DATA_PATH=v2_smart_imputation/imputed_dataset_v2.csv

########################################
# Teste de autenticação Supabase (src/validation/test_supabase_auth.py)
########################################

TEST_DB_HOST=
TEST_DB_PORT=6543
TEST_DB_USER=
TEST_DB_PASSWORD=
TEST_DB_NAME=postgres

